# Copy to .env and fill in values.

# OpenRouter (required for chat / agent LLM when using default model id)
OPENROUTER_API_KEY=

# Indian Kanoon API key for the RAG ingestion pipeline.
KANOON_API_KEY=

# When true, the LangGraph run uses ChromaDB retrieval (Research → Compliance → Synthesis).
# When false, requests use plain chat only (no vector retrieval).
CHROMA_READY=false

# Persistent Chroma directory (created automatically).
CHROMA_PERSIST_DIR=data/chroma

# Chroma collection name for the legal corpus.
CHROMA_COLLECTION=nyaya

# SQLite path for six-message window + rolling summary per session.
SQLITE_PATH=data/nyaya_chat.sqlite3

# Chat model id for init_chat_model (see LangChain OpenRouter docs).
CHAT_MODEL_ID=openai/gpt-oss-120b:free

# Max tool rounds for the Research ReAct loop (Compliance/Synthesis remain single-pass scaffolds).
MAX_REACT_ITERATIONS=6
