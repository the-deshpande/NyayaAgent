# Nyaya Agent — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to git

# Required: Google Gemini API Key
# Get it at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Indian Kanoon API Key
# Get it at: https://api.indiankanoon.org/
INDIANKANOON_API_KEY=your_indiankanoon_api_key_here
